# Environment Configuration
# This file contains all required environment variables for the Academy LMS

# =============================================================================
# BACKEND CONFIGURATION
# =============================================================================

# Server Host and Port
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Database Configuration
# Data is stored in data/db.json with file locking to prevent concurrent corruption
DATABASE_TYPE=json  # json (for now), can be extended to postgresql, mongodb
DATABASE_PATH=data/db.json

# =============================================================================
# AUTHENTICATION
# =============================================================================

# JWT Secret - CHANGE THIS IN PRODUCTION!
SECRET_KEY=your-secret-key-change-in-production-12345

# Token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Admin account credentials (initial setup only)
# After first login, change password in admin panel
ADMIN_EMAIL=zubairahmadisb7p2@gmail.com
ADMIN_PASSWORD=12345678  # CHANGE THIS AFTER FIRST LOGIN

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# =============================================================================
# FILE UPLOADS
# =============================================================================

# Maximum file size for uploads (in MB)
MAX_UPLOAD_SIZE_MB=10

# Upload directory
UPLOAD_DIR=public/uploads

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================

# Environment: development, staging, production
ENVIRONMENT=development

# Enable debug mode
DEBUG=true

# =============================================================================
# OPTIONAL: Cloud Services (for future migration)
# =============================================================================

# Supabase (alternative to local persistence)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-api-key

# Firebase (alternative to local persistence)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_API_KEY=your-api-key
